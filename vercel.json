{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix frontend install && npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/tutor/:path*", "destination": "/api/index.py" },
    { "source": "/sync/:path*", "destination": "/api/index.py" },
    { "source": "/rag/:path*", "destination": "/api/index.py" },
    { "source": "/analytics/:path*", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/docs", "destination": "/api/index.py" },
    { "source": "/openapi.json", "destination": "/api/index.py" },
    { "source": "/redoc", "destination": "/api/index.py" }
  ]
}
